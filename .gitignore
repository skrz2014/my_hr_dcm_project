# Snowflake DCM Projects — .gitignore
# Author: Satish Kumar | @snowflakechronicles

# ── DCM output directory (auto-generated by PLAN / DEPLOY) ──────────────────
out/
*.plan.json
*.deploy.json

# ── Snowflake CLI config (contains credentials — never commit) ───────────────
.snowflake/
config.toml
~/.snowflake/

# ── Environment files ────────────────────────────────────────────────────────
.env
.env.local
.env.dev
.env.stage
.env.prod
*.env

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
.venv/
env/
pip-log.txt

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temp / OS ────────────────────────────────────────────────────────────────
tmp/
temp/
.tmp/
